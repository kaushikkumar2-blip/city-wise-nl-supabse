# Railway Variables (do not commit real values)
#
# EASIEST: paste Supabase "Session pooler" URI as one variable:
# DATABASE_URL=postgresql://postgres.PROJECTREF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# (URL-encode special characters in the password, e.g. $ -> %24)
#
# OR set these separately:
POSTGRES_HOST=aws-1-ap-south-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.yourprojectref
POSTGRES_PASSWORD=

# Optional: REST upload fallback if Postgres insert fails
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=
